# Multi-target Dockerfile for the Go binaries. Pick the build target via
# --build-arg BIN=server (default) or BIN=indexer.
FROM golang:1.22-alpine AS build
WORKDIR /src
ARG BIN=server
ENV CGO_ENABLED=0 GOFLAGS=-trimpath
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -ldflags='-s -w' -o /out/app ./cmd/${BIN}

FROM gcr.io/distroless/static:nonroot
COPY --from=build /out/app /app
EXPOSE 8080
USER nonroot:nonroot
ENTRYPOINT ["/app"]
